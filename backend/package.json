{
  "name": "lotacoes-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "node -e \"console.log('build ok: backend/public already bundled')\"",
    "start": "node src/server.js",
    "start:probe": "node src/probe.js",
    "test": "vitest run",
    "build:frontend": "npm --prefix ../frontend ci && npm --prefix ../frontend run build",
    "sync:public": "node ./scripts/sync-public-from-frontend.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
