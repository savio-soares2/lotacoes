{
  "name": "lotacoes-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "prestart": "node ./scripts/ensure-frontend-build.mjs",
    "start": "node src/server.js",
    "test": "vitest run",
    "build:frontend": "npm --prefix ../frontend ci --include=dev && npm --prefix ../frontend run build",
    "postinstall": "node ./scripts/ensure-frontend-build.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
