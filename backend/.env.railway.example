# Railway / production (single service: backend + frontend)
# Railway injeta PORT automaticamente; nao fixe PORT aqui.
HOST=0.0.0.0
FALLBACK_PORTS=3000,8080,5000
JWT_SECRET=replace-with-a-strong-secret
CORS_ORIGINS=https://saude.palmas.online,https://www.saude.palmas.online
FRONTEND_DIST=public
DATA_DIR=/tmp/lotacoes-data
UPLOAD_DIR=/tmp/lotacoes-data/uploads
TRUST_PROXY=1

# First admin bootstrap (required when users table is empty)
ADMIN_BOOTSTRAP_USERNAME=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password

# Optional first gestao user bootstrap
GESTAO_BOOTSTRAP_USERNAME=
GESTAO_BOOTSTRAP_PASSWORD=

# Reference files packaged with backend
REF_SERVERS_FILE=data/UPAS POR CARGO - 13-03-2026.xlsx
REF_VAGAS_FILE=data/Quadro de Vagas Edital.xlsx
REF_VAGAS_SHEET=Página1
REF_VAGAS_HEADER_ROW=1
REF_VAGAS_DATA_START_ROW=2
REF_VAGAS_DATA_END_ROW=44
